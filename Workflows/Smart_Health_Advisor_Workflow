      "parameters": {
        "jsCode": "// 1. รับค่า Input (ปรับให้ปลอดภัยกัน error)\n// สมมติว่า items[0] คือผลจาก AI และ items[1] คือค่าเดิมจาก webhook\nconst aiReplyRaw = items[0]?.json?.output || ''; \nconst contextItem = items[1]?.json || {};\n\nconst chatInput = contextItem.chatInput || '';\nconst replyToken = contextItem.replyToken || '';\nconst sessionId = contextItem.sessionId || '';\nconst importance_memory = contextItem.importance_memory || '';\nconst type = contextItem.type || '';\n\n// 2. ประกาศตัวแปรสำหรับเก็บค่า (Default values)\nlet status = \"unknown\"; \nlet name = \"\";\nlet calories = \"\";\nlet carbs = \"\";\nlet protein = \"\";\nlet fat = \"\";\nlet sugar = \"\";\nlet sodium = \"\";\nlet summary = \"\";\n\n// 3. เริ่มกระบวนการ Parse ข้อมูล (แบบ Text Regex เพราะ AI ตอบกลับมาเป็น Text Form)\n\n// --- [จุดที่แก้ไข] ปรับ Regex ให้ยืดหยุ่น รับ status ได้แม้ฟันหนูไม่ครบ ---\nconst statusMatch = aiReplyRaw.match(/status\"?\\s*=\\s*(\\w+)/i);\nif (statusMatch) {\n    status = statusMatch[1];\n}\n// -------------------------------------------------------------\n\n// ตรวจจับค่าต่างๆ ด้วย Regex ภาษาไทย\nconst nameMatch = aiReplyRaw.match(/ชื่อเมนู:\\s*(.+)/);\nif (nameMatch) name = nameMatch[1].trim();\n\nconst calMatch = aiReplyRaw.match(/พลังงานโดยประมาณ:\\s*(.+)/);\nif (calMatch) calories = calMatch[1].trim();\n\nconst carbsMatch = aiReplyRaw.match(/- คาร์โบไฮเดรต:\\s*(.+)/);\nif (carbsMatch) carbs = carbsMatch[1].trim();\n\nconst protMatch = aiReplyRaw.match(/- โปรตีน:\\s*(.+)/);\nif (protMatch) protein = protMatch[1].trim();\n\nconst fatMatch = aiReplyRaw.match(/- ไขมัน:\\s*(.+)/);\nif (fatMatch) fat = fatMatch[1].trim();\n\nconst sugarMatch = aiReplyRaw.match(/- น้ำตาล:\\s*(.+)/);\nif (sugarMatch) sugar = sugarMatch[1].trim();\n\nconst sodMatch = aiReplyRaw.match(/- โซเดียม:\\s*(.+)/);\nif (sodMatch) sodium = sodMatch[1].trim();\n\nconst sumMatch = aiReplyRaw.match(/สรุปสั้นๆ:\\s*(.+)/);\nif (sumMatch) summary = sumMatch[1].trim();\n\n\n// 4. จัดรูปแบบข้อความที่จะส่งกลับ (Formatted Message)\nlet formatted = aiReplyRaw; // ค่าเริ่มต้น (เผื่อไม่ใช่ food)\n\nif (status === 'food' || name !== \"\") {\n    // ถ้าเป็นอาหาร ให้จัดรูปแบบสวยงาม\n    formatted = `ชื่อเมนู: ${name}\\n` +\n                `พลังงาน: ${calories}\\n\\n` +\n                `สารอาหาร:\\n` +\n                `- คาร์โบไฮเดรต: ${carbs}\\n` +\n                `- โปรตีน: ${protein}\\n` +\n                `- ไขมัน: ${fat}\\n` +\n                `- น้ำตาล: ${sugar}\\n` +\n                `- โซเดียม: ${sodium}\\n\\n` +\n                `สรุป: ${summary}`;\n}\n\n// 5. ส่งค่ากลับ (Return Output)\nreturn [\n  {\n    json: {\n      // ข้อมูลดั้งเดิม\n      chatInput,\n      replyToken,\n      sessionId,\n      importance_memory,\n      type,\n      \n      // ข้อมูลจาก AI (Raw)\n      aiReply: aiReplyRaw,\n      \n      // ข้อมูลที่ประมวลผลแล้ว\n      status,          // <--- ตอนนี้ status จะถูกต้องแล้วครับ\n      formatted,       // <--- ข้อความที่จัด Format แล้วสำหรับส่ง LINE\n      \n      // ข้อมูลย่อย (เผื่อนำไปบันทึกลง Database)\n      food_data: {\n          name,\n          calories,\n          carbohydrates: carbs,\n          protein,\n          fat,\n          sugar,\n          sodium,\n          summary\n      }\n    }\n  }\n];"
