      "parameters": {
        "jsCode": "// 1. ค้นหาข้อมูล Context (Chat)\nconst contextItemObj = items.find(item => item.json.aiReply || item.json.chatInput);\nconst contextData = contextItemObj ? contextItemObj.json : {};\n\n// 2. ค้นหาข้อมูล User Profile\nconst targetSessionId = contextData.sessionId;\nlet userProfile = {};\n\nif (targetSessionId) {\n    const userItemObj = items.find(item => item.json.userId === targetSessionId);\n    if (userItemObj) {\n        userProfile = userItemObj.json;\n    }\n}\n\n// ดึงค่าพื้นฐาน\nconst aiReplyRaw = contextData.aiReply || contextData.output || ''; \nconst chatInput = contextData.chatInput || '';\nconst replyToken = contextData.replyToken || '';\nconst sessionId = contextData.sessionId || '';\nconst type = contextData.type || '';\nconst userName = userProfile.Name || ''; \n\n\n// --- [ส่วนคำนวณแคลอรี่ใหม่] ---\n\n// 1. ดึงแคลอรี่คงเหลือล่าสุดจาก Database (ถ้าไม่มีให้ใช้ 0)\nconst currentRemain = parseFloat(userProfile[\"calories remain\"] || 0);\n\n// 2. ดึงแคลอรี่ของอาหารมื้อนี้ (Parse จากข้อความ AI)\nlet foodCalories = 0;\nconst calMatch = aiReplyRaw.match(/พลังงานโดยประมาณ:\\s*([\\d\\.]+)/); // จับเฉพาะตัวเลข\nif (calMatch) {\n    foodCalories = parseFloat(calMatch[1]);\n}\n\n// 3. คำนวณยอดคงเหลือใหม่ (เอาคงเหลือเก่า - มื้อนี้)\nconst newRemaining = currentRemain - foodCalories;\n\n// ---------------------------\n\n\n// 3. Regex Parse ข้อมูลอื่นๆ (เหมือนเดิม)\nlet status = \"unknown\"; \nlet name = \"\";\nlet carbs = \"\";\nlet protein = \"\";\nlet fat = \"\";\nlet sugar = \"\";\nlet sodium = \"\";\nlet summary = \"\";\n\nconst statusMatch = aiReplyRaw.match(/status\"?\\s*=\\s*(\\w+)/i);\nif (statusMatch) status = statusMatch[1];\nelse if (contextData.status) status = contextData.status;\n\nconst nameMatch = aiReplyRaw.match(/ชื่อเมนู:\\s*(.+)/);\nif (nameMatch) name = nameMatch[1].trim();\n\nconst carbsMatch = aiReplyRaw.match(/- คาร์โบไฮเดรต:\\s*(.+)/);\nif (carbsMatch) carbs = carbsMatch[1].trim();\n\nconst protMatch = aiReplyRaw.match(/- โปรตีน:\\s*(.+)/);\nif (protMatch) protein = protMatch[1].trim();\n\nconst fatMatch = aiReplyRaw.match(/- ไขมัน:\\s*(.+)/);\nif (fatMatch) fat = fatMatch[1].trim();\n\nconst sugarMatch = aiReplyRaw.match(/- น้ำตาล:\\s*(.+)/);\nif (sugarMatch) sugar = sugarMatch[1].trim();\n\nconst sodMatch = aiReplyRaw.match(/- โซเดียม:\\s*(.+)/);\nif (sodMatch) sodium = sodMatch[1].trim();\n\nconst sumMatch = aiReplyRaw.match(/สรุปสั้นๆ:\\s*(.+)/);\nif (sumMatch) summary = sumMatch[1].trim();\n\n\n// 4. จัดรูปแบบข้อความที่จะส่งกลับ (Formatted Message)\nlet formatted = aiReplyRaw; \n\nif (status === 'food' || name !== \"\") {\n    let greeting = userName ? `คุณ ${userName} ครับ\\n` : \"\";\n    \n    // ตรวจสอบสถานะ (กินเกินหรือยัง?)\n    const isOver = newRemaining < 0;\n    const emoji = isOver ? \"🚨\" : \"✅\";\n    const statusText = isOver ? \"เกินโควตาไป\" : \"คงเหลือ\";\n    const showNumber = Math.abs(newRemaining).toFixed(0); // เอาเครื่องหมายลบออกเพื่อความสวยงาม\n\n    formatted = `${greeting}🍽️ บันทึกเมนู: ${name}\\n` +\n                `🔥 พลังงาน: ${foodCalories} kcal\\n\\n` +\n                `📊 สารอาหาร:\\n` +\n                `- คาร์บ: ${carbs}\\n` +\n                `- โปรตีน: ${protein}\\n` +\n                `- ไขมัน: ${fat}\\n\\n` +\n                `__________________\\n` +\n                `${emoji} ${statusText}: ${showNumber} kcal`;\n}\n\n// 5. ส่งค่ากลับ\nreturn [\n  {\n    json: {\n      // ข้อมูลดั้งเดิม\n      chatInput,\n      replyToken,\n      sessionId,\n      userName, \n      \n      // ข้อมูลการคำนวณ (สำคัญ: ส่งค่านี้ไปอัปเดต Database)\n      prev_remaining: currentRemain,  // คงเหลือเก่า\n      food_cal: foodCalories,         // มื้อนี้\n      new_remaining: newRemaining,    // คงเหลือใหม่ (เอาไป update ใน sheet)\n\n      // ข้อมูลแสดงผล\n      aiReply: aiReplyRaw,\n      status,          \n      formatted,       \n      \n      food_data: {\n          name,\n          calories: foodCalories, // ส่งเป็นตัวเลข\n          carbohydrates: carbs,\n          protein,\n          fat,\n          sugar,\n          sodium,\n          summary\n      }\n    }\n  }\n];"
      },
